# 管理员初始密码（首次启动生效）
ADMIN_PASSWORD=change-me

# 模型接入（Anthropic 兼容端点，三选一，也可填其他兼容端点）
# DeepSeek（按量，最便宜）— Anthropic 兼容端点必须带 /anthropic 后缀:
#   ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
#   MODEL=deepseek-v4-flash   # 快而省；复杂任务可换 deepseek-v4-pro
#   （deepseek-chat / deepseek-reasoner 将于 2026-07-24 弃用，勿用）
# GLM（智谱）:
#   ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
#   MODEL=glm-4.6
# Kimi（月之暗面）:
#   ANTHROPIC_BASE_URL=https://api.moonshot.cn/anthropic
#   MODEL=kimi-k2-turbo-preview
# 切换 Claude 官方 API：ANTHROPIC_BASE_URL 留空、填官方 key、MODEL 填 claude 型号
# 注意：各家端点与模型名以官方文档为准
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_API_KEY=sk-your-key
MODEL=deepseek-v4-flash

# Windows 宿主机需把 HOST_DATA_DIR 设为 data 目录的绝对路径，如 D:/code/agent/data
# Linux 下留空即可（默认 $PWD/data）
#HOST_DATA_DIR=

CONCURRENCY=2
TASK_TIMEOUT_MINUTES=30
